{
	"manifest_version": 3,
	"name": "Little Later",
	"version": "2.0.0",
	"description": "A local-first Chrome extension for visual bookmarks, tasks, reminders, notes, and AI workflows.",
	"key": "",
	"permissions": [
		"storage",
		"tabs",
		"activeTab",
		"unlimitedStorage",
		"contextMenus",
		"alarms",
		"declarativeNetRequest",
		"notifications"
	],
	"host_permissions": ["<all_urls>"],
	"action": {
		"default_popup": "index.html"
	},
	"background": {
		"service_worker": "src/background/background.ts",
		"type": "module"
	},
	"web_accessible_resources": [
		{
			"resources": ["icons/*", "images/*", "fonts/*", "videos/*"],
			"matches": ["<all_urls>"]
		}
	],
	"icons": {
		"16": "icons/little-later-16x16.png",
		"48": "icons/little-later-48x48.png",
		"128": "icons/little-later-128x128.png"
	}
}
